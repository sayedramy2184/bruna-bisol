# === REQUIRED ===
# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# === OPTIONAL (for email sending) ===
# Resend API key (get one at https://resend.com — free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Bruna's email — receives a notification for each new lead
BRUNA_EMAIL=hello@brunabisol.com

# Sender email — must be a verified domain on Resend
# For testing, you can use: onboarding@resend.dev
FROM_EMAIL=hello@brunabisol.com
